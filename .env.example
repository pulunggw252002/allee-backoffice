# ============================================================
# ALLEE Backoffice — environment template.
# Copy to `.env.local` for local dev, or set these in the deploy host.
# All NEXT_PUBLIC_* are embedded at build time.
# ============================================================

# ---- App identity (shown in sidebar / page titles) ----
NEXT_PUBLIC_APP_NAME="ALLEE Backoffice"
NEXT_PUBLIC_APP_SHORT_NAME="ALLEE"
NEXT_PUBLIC_APP_VERSION="0.1.0"
NEXT_PUBLIC_APP_CHANNEL="MVP"

# ---- Locale / currency ----
NEXT_PUBLIC_LOCALE="id-ID"
NEXT_PUBLIC_CURRENCY_CODE="IDR"
NEXT_PUBLIC_CURRENCY_SYMBOL="Rp"
NEXT_PUBLIC_TIMEZONE="Asia/Jakarta"

# ---- Storage (localStorage key namespace) ----
# Keys become `<prefix>:<version>:<name>`, e.g. `allee:v1:auth`.
NEXT_PUBLIC_STORAGE_PREFIX="allee"
NEXT_PUBLIC_STORAGE_VERSION="v6"

# ---- API / backend ----
# When USE_REAL_BACKEND=false (default) the mock in-memory layer is used.
# When true, API calls are proxied to BASE_URL.
NEXT_PUBLIC_USE_REAL_BACKEND="false"
# Leave empty for same-origin (recommended when Next.js hosts /api routes).
# Set to an absolute URL when the API lives on a separate host.
NEXT_PUBLIC_API_BASE_URL=""
# Simulated latency for the mock (ms).
NEXT_PUBLIC_MOCK_LATENCY_MS="120"
# TanStack Query staleTime (ms). 0 = always refetch.
NEXT_PUBLIC_QUERY_STALE_MS="30000"

# ---- Images ----
# Comma-separated hostnames allowed by next/image.
NEXT_PUBLIC_IMAGE_REMOTE_HOSTS="images.unsplash.com"

# ============================================================
# Backend (server-only — DO NOT prefix with NEXT_PUBLIC_)
# ============================================================

# SQLite file location. Dev default creates `./data/app.db`.
# On the VPS, prefer an absolute path like `/var/lib/allee/app.db`.
DATABASE_URL="./data/app.db"

# Better Auth session secret. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
BETTER_AUTH_SECRET="change-me-to-a-long-random-string-min-32-chars"

# Public origin the browser reaches the app at. Drives cookie domain + CSRF.
BETTER_AUTH_URL="http://localhost:3000"
